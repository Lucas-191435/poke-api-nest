// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  CLIENT
}

enum Region {
  KANTO
  JOHTO
  HOENN
  SINNOH
  UNOVA
}

enum ItemCategory {
  pokeballs
  healing
  pp_recovery
  battle_items
  held_items
  evolution
  berries_food
  machines
  collectibles
  key_items
  mail
  crafting
  special_mechanics
  fossils_and_mining
}

model User {
  id               String      @id @default(uuid())
  email            String      @unique
  password         String?
  role             Role        @default(CLIENT)
  name             String
  avatar           String?
  birthday         DateTime?
  oauthId          String?     @unique
  oauthProvider    String?
  oauthProfileUrl  String?
  resetToken       String?     @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  myPokemons       MyPokemon[]

  @@map("users") // Nome da tabela no banco de dados
}

model Pokemon {
  id        String  @id @default(uuid())
  pokeId    Int     @unique
  name      String
  img1      String?
  img2      String?
  img3      String?
  types     String?
  abilities String?
  height    Float   @default(0)
  weight    Float   @default(0)

  hp    Int @default(0)
  atk   Int @default(0)
  def   Int @default(0)
  spAtk Int @default(0)
  spDef Int @default(0)
  speed Int @default(0)

  region       Region        @default(KANTO)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pokemonMoves PokemonMove[]
  myPokemons   MyPokemon[]

  @@map("Pokemon") // Nome da tabela no banco de dados
}

model Item {
  id               String        @id @default(uuid())
  pokeItemId       Int           @unique
  pokeCategoryId   Int?
  pokeItemPocketId Int?
  name             String
  sprite           String?
  category         ItemCategory?
  description      String?
  effect           String?
  isConsumable     Boolean       @default(false)
  isHeldItem       Boolean       @default(false)
  isBattleUse      Boolean       @default(false)
  isDiscardable    Boolean       @default(false)
  isPokemonUse     Boolean       @default(false)
  price            Int?
  regions          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moves PokemonMove[]

  @@map("items") // Nome da tabela no banco de dados
}

model Move {
  id            String  @id @default(uuid())
  pokeMoveId    Int     @unique
  name          String  @unique
  accuracy      Int?
  power         Int?
  pp            Int?
  priority      Int?
  type          String?
  description   String?
  target        String?
  damage_class  String?
  effect        String?
  effect_chance Int?
  ailment       String?
  category      String?
  crit_rate     Int?
  drain         Int?
  flinch_chance Int?
  healing       Int?
  min_hits      Int?
  max_hits      Int?
  min_turns     Int?
  max_turns     Int?
  stat_chance   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pokemons PokemonMove[]

  @@map("moves") // Nome da tabela no banco de dados
}

enum LearnMethod {
  LEVEL_UP
  MACHINE
  EGG
  TUTOR
  UNKNOWN
}

model PokemonMove {
  id           String      @id @default(uuid())
  pokemonId    String
  moveId       String
  learn_method LearnMethod @default(UNKNOWN)
  level        Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pokemon Pokemon @relation(fields: [pokemonId], references: [id])
  move    Move    @relation(fields: [moveId], references: [id])
  item    Item?   @relation(fields: [itemId], references: [id])
  itemId  String?

  // myPokemonMoves MyPokemonMoves[]

  @@map("pokemon_moves")
}

model MyPokemon {
  id        String  @id @default(uuid())
  userId    String
  pokemonId String
  nickname  String?

  teamAlpha Boolean? @default(false)
  teamBeta  Boolean? @default(false)
  teamGamma Boolean? @default(false)

  teamAlphaMove Json @default("[]")
  teamBetaMove  Json @default("[]")
  teamGammaMove Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  pokemon Pokemon @relation(fields: [pokemonId], references: [id])

  // myPokemonMoves MyPokemonMoves[]
  @@unique([userId, pokemonId]) // Esta linha cria a constraint única
  @@map("my_pokemon")
}

